{
  "name": "terminal-realtime-chat",
  "version": "1.4.1",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:cli": "node scripts/build-cli.mjs",
    "dev:server": "tsx src/presentation/server/server.ts",
    "dev:cli": "tsx src/presentation/cli/index.ts",
    "start:server": "node dist/presentation/server/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "test": "jest --passWithNoTests --coverage",
    "test:watch": "jest --watch",
    "build:frontend": "npm --prefix frontend run build",
    "build:all": "npm run build && npm run build:frontend"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.11.1",
    "multer": "^2.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^9.0.0"
  },
  "pkg": {
    "assets": ["src/assets/**/*"]
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.18",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.18.12",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "@yao-pkg/pkg": "^5.16.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.5",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.20.1",
    "typescript": "^6.0.3"
  }
}
